#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
skills_dir="$repo_root/skills"

targets=(
  "$HOME/.agents/skills"
  "$HOME/.claude/skills"
)

if [[ ! -d "$skills_dir" ]]; then
  echo "missing skills directory: $skills_dir" >&2
  exit 1
fi

for target in "${targets[@]}"; do
  mkdir -p -- "$target"
done

status=0

for skill_dir in "$skills_dir"/*; do
  [[ -d "$skill_dir" ]] || continue
  [[ -f "$skill_dir/SKILL.md" ]] || continue

  skill_name="$(basename -- "$skill_dir")"

  for target in "${targets[@]}"; do
    link_path="$target/$skill_name"

    if [[ -L "$link_path" ]]; then
      current_target="$(readlink -- "$link_path")"
      if [[ "$current_target" == "$skill_dir" ]]; then
        echo "ok: $link_path -> $skill_dir"
      else
        ln -sfnT -- "$skill_dir" "$link_path"
        echo "relinked: $link_path -> $skill_dir"
      fi
    elif [[ -e "$link_path" ]]; then
      echo "conflict: $link_path exists and is not a symlink" >&2
      status=1
    else
      ln -sT -- "$skill_dir" "$link_path"
      echo "linked: $link_path -> $skill_dir"
    fi
  done
done

exit "$status"
